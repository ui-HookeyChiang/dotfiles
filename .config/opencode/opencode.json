{
  "$schema": "https://opencode.ai/config.json",
  "model": "github-copilot/claude-opus-4.6",
  "permission": {
    "*": "allow",
    "external_directory": "allow",
    "bash": {
      "*": "allow",
      "rm -rf /": "deny",
      "rm -rf /*": "deny",
      "git push --force *": "deny",
      "git push -f *": "deny",
      "git reset --hard *": "deny",
      "git add -A": "deny",
      "git add --all": "deny",
      "git add .": "deny",
      "gh pr edit * --title *": "deny",
      "gh pr edit --title *": "deny",
      "grep *": "deny",
      "egrep *": "deny",
      "fgrep *": "deny",
      "find *": "deny"
    }
  },
  "instructions": [
    "~/.config/opencode/memory-discipline.md",
    "~/.config/opencode/terse-output.md"
  ],
  "agent": {
    "general": {
      "mode": "subagent",
      "prompt": "{file:./agents/general.md}"
    },
    "explore": {
      "mode": "subagent",
      "prompt": "{file:./agents/explore.md}"
    }
  },
  "plugin": [
    "./plugins/skill-dev-hooks.ts"
  ]
}
