# ~/.tmux.conf.local — user-owned override for oh-my-tmux.
# Loaded via TMUX_CONF_LOCAL env var (set in ~/.zshenv).
# Do NOT edit ~/.config/tmux/.tmux.conf.local (that's the submodule's vanilla template).

# -- clipboard ----------------------------------------------------------------
# Cross-platform clipboard: pbcopy on macOS, xclip on Linux.
# Detected at runtime via uname so the same file works on both.

if-shell 'command -v pbcopy >/dev/null 2>&1' \
    "set -gq @copy_use_osc52_fallback off ; \
     bind-key -T copy-mode-vi y send-keys -X copy-pipe-and-cancel 'pbcopy' ; \
     bind-key -T copy-mode-vi Enter send-keys -X copy-pipe-and-cancel 'pbcopy'"

if-shell 'command -v xclip >/dev/null 2>&1 && [ -z "${SSH_CONNECTION:-}" ] && [ -n "${DISPLAY:-}" ]' \
    "bind-key -T copy-mode-vi y send-keys -X copy-pipe-and-cancel 'xclip -in -selection clipboard' ; \
     bind-key -T copy-mode-vi Enter send-keys -X copy-pipe-and-cancel 'xclip -in -selection clipboard'"

# -- OSC 52 fallback for SSH-without-X ----------------------------------------
# When neither pbcopy nor xclip applies (typical SSH session into a Linux host
# with no $DISPLAY), fall through to tmux's built-in OSC 52 path. The terminal
# emulator on the local end receives the escape sequence and writes the
# selection into the system clipboard. Requires:
#   - set-clipboard on  (default in tmux 3.2+; explicit here)
#   - terminal-features tells tmux the outer terminal can decode OSC 52
#   - iTerm2: enable "Applications in terminal may access clipboard"
#     (Preferences > General > Selection)
set -gq set-clipboard on
set -ag terminal-features ",tmux-256color:clipboard"
set -ag terminal-features ",xterm-256color:clipboard"

# -- alternate-screen scrollback ----------------------------------------------
# Disable the alternate screen (smcup/rmcup) for ALL full-screen TUI apps so
# their output lands in the normal scrollback buffer. Without this, apps like
# Claude Code, nvim, less, and htop run in tmux's alternate screen — which has
# NO scrollback (history_size stays ~2 lines), so `prefix + [` enters copy-mode
# on an empty buffer and appears broken. The `@` suffix clears the smcup/rmcup
# capabilities, forcing those apps to render inline.
#
# Trade-off: apps no longer restore the previous screen on exit, so their full
# output stays in scrollback (visible clutter after quitting nvim/less). This
# prioritizes "scroll Claude Code output with prefix + [" over a clean restore.
set -ga terminal-overrides ',*:smcup@:rmcup@'

# -- mouse --------------------------------------------------------------------
# Enable mouse so drag-select routes through tmux (pane-aware), and the
# MouseDragEnd1Pane binding fires copy-pipe-and-cancel — which then either
# pbcopy/xclips above, or falls through to OSC 52.
set -g mouse on

# Force mouse drag to ALWAYS enter tmux copy-mode, even when the application
# in the pane (nvim, claude code TUI, less) has requested mouse reporting.
# Without this override, tmux's default `bind -T root MouseDrag1Pane if-shell
# ... { send-keys -M } { copy-mode -M }` forwards the drag into the app, which
# then handles it however it likes (nvim: move cursor; claude TUI: ignored);
# the user cannot copy text from app panes to the system clipboard.
#
# Trade-off: app-internal mouse interactions (nvim split focus on click,
# scrollback in less, etc.) stop working in mouse-enabled panes — users must
# use keyboard equivalents (Ctrl-W for nvim splits, vi-keys for less). This is
# an explicit prioritization of "copy text to clipboard" over "app mouse UX".
bind-key -T root MouseDrag1Pane if-shell -F '#{pane_in_mode}' 'send-keys -M' 'copy-mode -M'

# -- vim-tmux-navigator -------------------------------------------------------
# Ctrl-h/j/k/l navigate splits in vim/nvim AND panes in tmux, seamlessly.
# When the current pane runs vim/nvim, forward the key into the editor so the
# editor's plugin (mrjones2014/smart-splits.nvim, already installed in
# ~/.config/nvim) handles the move; otherwise tmux selects the adjacent pane
# directly. Regex copied verbatim from smart-splits.nvim README — must stay in
# sync with the nvim-side plugin's detection pattern.
#
# Note: `grep -iqE` here is intentional and portable — tmux's `if-shell` runs
# in a minimal POSIX shell on the user's system where `rg` may not exist.
is_vim="ps -o state= -o comm= -t '#{pane_tty}' | grep -iqE '^[^TXZ ]+ +(\\S+\\/)?g?(view|n?vim?x?)(diff)?$'"
bind-key -n C-h if-shell "$is_vim" 'send-keys C-h' 'select-pane -L'
bind-key -n C-j if-shell "$is_vim" 'send-keys C-j' 'select-pane -D'
bind-key -n C-k if-shell "$is_vim" 'send-keys C-k' 'select-pane -U'
bind-key -n C-l if-shell "$is_vim" 'send-keys C-l' 'select-pane -R'

# Same bindings inside copy-mode-vi so navigation works during text selection.
bind-key -T copy-mode-vi C-h select-pane -L
bind-key -T copy-mode-vi C-j select-pane -D
bind-key -T copy-mode-vi C-k select-pane -U
bind-key -T copy-mode-vi C-l select-pane -R

# These bindings OVERRIDE oh-my-tmux's `bind -n C-l send-keys C-l \; clear-history`
# (this .tmux.conf.local is sourced AFTER the main oh-my-tmux conf). To wipe
# scrollback use `prefix + Ctrl+l` instead (prefix-protected, still works).

# -- placeholder for future user customization --------------------------------
# Append your tweaks below this line. See ~/.config/tmux/.tmux.conf.local for
# the full list of oh-my-tmux variables you can override (prefix, theme, etc.).

# oh-my-tmux defaults to 5000 lines, which fills up fast and makes
# `prefix + [` scroll-back feel broken. 50000 is ~10x with negligible RAM.
set -g history-limit 50000

# -- true color ---------------------------------------------------------------
set -g default-terminal "tmux-256color"
set -ag terminal-overrides ",xterm-256color:RGB"
