{
  "$schema": "https://opencode.ai/config.json",
  "model": "anthropic/claude-sonnet-4-5",
  "permission": {
    "*": "allow",
    "external_directory": "allow",
    "bash": {
      "*": "allow",
      "rm -rf /": "deny",
      "rm -rf /*": "deny",
      "git push --force *": "deny",
      "git push -f *": "deny",
      "git reset --hard *": "deny",
      "git add -A": "deny",
      "git add --all": "deny",
      "git add .": "deny"
    }
  },
  "instructions": [
    "~/.config/opencode/memory-discipline.md",
    "~/.config/opencode/sandbox-protected-paths.md",
    "~/.config/opencode/shell-tools.md"
  ]
}
